# =============================================================================
# GFF ERP Enterprise - Backend Environment Variables
# =============================================================================
# Description: Complete environment configuration template for the backend
# Version: 1.0
# Copy to .env and update values for your environment
# =============================================================================

# =============================================================================
# Application
# =============================================================================
# Node environment: development | staging | production
NODE_ENV=production

# Application port (must match Nginx upstream)
PORT=3000

# Host to bind (127.0.0.1 for local-only, 0.0.0.0 for all interfaces)
HOST=127.0.0.1

# Application name
APP_NAME="GFF ERP Enterprise"

# Application version
APP_VERSION=1.0.0

# =============================================================================
# Database
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=SCHEMA&PARAMS
# IMPORTANT: Change the password for production!
DATABASE_URL="postgresql://gff_erp_user:ChangeThisPassword@localhost:5432/gff_erp_db?schema=public&connection_limit=20&pool_timeout=30"

# =============================================================================
# JWT Authentication
# =============================================================================
# JWT signing secret - MUST be a long random string for production!
# Generate with: openssl rand -base64 64
# Minimum length: 32 characters (recommended: 64+)
JWT_SECRET=your-super-secret-jwt-key-change-this-to-a-long-random-string-minimum-64-characters

# JWT refresh token secret - different from JWT_SECRET!
# Generate with: openssl rand -base64 64
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-to-another-long-random-string

# Access token expiry in seconds (default: 900 = 15 minutes)
JWT_EXPIRY=900

# Refresh token expiry in seconds (default: 604800 = 7 days)
JWT_REFRESH_EXPIRY=604800

# Token issuer
JWT_ISSUER=gff-erp

# Token audience
JWT_AUDIENCE=gff-erp-client

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Comma-separated list of allowed origins
# For production, specify exact domains only
CORS_ORIGINS=https://erp.yourdomain.com,https://admin.yourdomain.com

# Allowed HTTP methods
CORS_METHODS=GET,POST,PUT,PATCH,DELETE

# Allow credentials (cookies/auth headers)
CORS_CREDENTIALS=true

# =============================================================================
# Security
# =============================================================================
# Bcrypt rounds for password hashing (12-14 recommended for production)
# Higher = more secure but slower
BCRYPT_ROUNDS=12

# Maximum login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in seconds (default: 900 = 15 minutes)
LOCKOUT_DURATION=900

# Session secret for express sessions (if used)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-change-this-to-a-random-string

# =============================================================================
# Logging
# =============================================================================
# Log level: debug | info | warn | error | fatal
LOG_LEVEL=info

# Log file path
LOG_FILE=/var/log/gff-erp/app.log

# Maximum log file size before rotation (e.g., 20m)
LOG_MAX_SIZE=20m

# Maximum number of log files to keep
LOG_MAX_FILES=30

# =============================================================================
# File Uploads
# =============================================================================
# Upload directory (absolute path)
UPLOAD_DIR=/opt/gff-erp/uploads

# Maximum file size in bytes (default: 10485760 = 10MB)
MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated MIME types)
# Leave empty to allow all
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# =============================================================================
# Company Information
# =============================================================================
# Company name (displayed in reports and UI)
COMPANY_NAME="GFF ERP Enterprise"

# Company logo path (relative to uploads or URL)
COMPANY_LOGO=/assets/logo.png

# Default language: ar | en
DEFAULT_LANGUAGE=ar

# Default currency code: SAR | USD | EUR | GBP
DEFAULT_CURRENCY=SAR

# Company address (for invoices)
COMPANY_ADDRESS="123 Business Street, Riyadh, Saudi Arabia"

# Company phone
COMPANY_PHONE=+966123456789

# Company email
COMPANY_EMAIL=info@gff-erp.com

# Company VAT/Tax number
COMPANY_TAX_NUMBER=310123456700003

# =============================================================================
# Email Configuration (Optional)
# =============================================================================
# SMTP host
SMTP_HOST=

# SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP username
SMTP_USER=

# SMTP password
SMTP_PASS=

# From address
SMTP_FROM=noreply@gff-erp.com

# From name
SMTP_FROM_NAME="GFF ERP"

# Enable TLS
SMTP_SECURE=false

# =============================================================================
# Redis Configuration (Optional - for caching and sessions)
# =============================================================================
# Redis URL (leave empty to disable Redis)
# REDIS_URL=redis://localhost:6379/0

# Redis password (if required)
# REDIS_PASSWORD=

# Cache TTL in seconds (default: 300 = 5 minutes)
# REDIS_CACHE_TTL=300

# =============================================================================
# Feature Flags
# =============================================================================
# Enable audit logging (tracks all mutations)
ENABLE_AUDIT_LOG=true

# Enable auto-generation of accounting journal entries
ENABLE_AUTO_JOURNAL=true

# Enable push notifications
ENABLE_NOTIFICATIONS=false

# Enable multi-currency support
ENABLE_MULTI_CURRENCY=false

# Enable advanced analytics
ENABLE_ANALYTICS=false

# Enable email notifications
ENABLE_EMAIL=false

# Enable SMS notifications
ENABLE_SMS=false

# =============================================================================
# Rate Limiting
# =============================================================================
# General API rate limit (requests per minute)
RATE_LIMIT_GENERAL=120

# Authentication rate limit (requests per minute)
RATE_LIMIT_AUTH=10

# Report generation rate limit (requests per minute)
RATE_LIMIT_REPORT=10

# Upload rate limit (requests per minute)
RATE_LIMIT_UPLOAD=10

# =============================================================================
# Payroll Configuration
# =============================================================================
# GOSI (Social Insurance) employer percentage
GOSI_EMPLOYER_PERCENTAGE=12

# GOSI employee percentage
GOSI_EMPLOYEE_PERCENTAGE=10

# Default working hours per day
DEFAULT_WORKING_HOURS=8

# Default working days per month
DEFAULT_WORKING_DAYS=22

# =============================================================================
# API Configuration
# =============================================================================
# API base path
API_PREFIX=/api

# API version
API_VERSION=v1

# Default page size for pagination
DEFAULT_PAGE_SIZE=20

# Maximum page size
MAX_PAGE_SIZE=100

# =============================================================================
# Health Check
# =============================================================================
# Health check endpoint path
HEALTH_PATH=/api/health

# Enable detailed health check (includes DB, disk, memory stats)
HEALTH_DETAILED=true
