# =============================================================================
# GFF ERP Enterprise - Frontend Environment Variables
# =============================================================================
# Description: Complete environment configuration template for the frontend
# Version: 1.0
# Copy to .env and update values for your environment
# =============================================================================

# =============================================================================
# API Configuration
# =============================================================================
# Base URL for API requests (without trailing slash)
# Development: http://localhost:3000/api
# Staging: https://staging.erp.yourdomain.com/api
# Production: https://erp.yourdomain.com/api
VITE_API_BASE_URL=https://erp.yourdomain.com/api

# API request timeout in milliseconds (default: 30000 = 30 seconds)
VITE_API_TIMEOUT=30000

# =============================================================================
# Application Information
# =============================================================================
# Application name (displayed in browser tab and header)
VITE_APP_NAME="GFF ERP Enterprise"

# Application short name (for mobile homescreen)
VITE_APP_SHORT_NAME="GFF ERP"

# Application version
VITE_APP_VERSION=1.0.0

# Application description
VITE_APP_DESCRIPTION="GFF ERP Enterprise - Feed Distribution, Manufacturing & Poultry Management System"

# =============================================================================
# Localization
# =============================================================================
# Default language: ar (Arabic) | en (English)
VITE_DEFAULT_LANGUAGE=ar

# Supported languages (comma-separated)
VITE_SUPPORTED_LANGUAGES=ar,en

# Enable RTL (Right-to-Left) layout for Arabic
VITE_ENABLE_RTL=true

# Default date format
VITE_DATE_FORMAT=DD/MM/YYYY

# Default time format
VITE_TIME_FORMAT=HH:mm

# First day of week (0=Sunday, 1=Monday, 6=Saturday)
# Saudi Arabia: 0 (Sunday)
VITE_FIRST_DAY_OF_WEEK=0

# =============================================================================
# Currency
# =============================================================================
# Default currency code
VITE_DEFAULT_CURRENCY=SAR

# Currency symbol position: before | after
VITE_CURRENCY_SYMBOL_POSITION=before

# Number format locale
VITE_NUMBER_LOCALE=ar-SA

# =============================================================================
# UI Configuration
# =============================================================================
# Default theme: light | dark | system
VITE_DEFAULT_THEME=light

# Sidebar default state: expanded | collapsed
VITE_SIDEBAR_DEFAULT=expanded

# Default page size for data tables
VITE_DEFAULT_PAGE_SIZE=20

# Page size options for data tables (comma-separated)
VITE_PAGE_SIZE_OPTIONS=10,20,50,100

# Maximum file upload size in bytes (10MB = 10485760)
VITE_MAX_FILE_SIZE=10485760

# Enable animations
VITE_ENABLE_ANIMATIONS=true

# =============================================================================
# Feature Flags
# =============================================================================
# Enable notifications UI
VITE_ENABLE_NOTIFICATIONS=false

# Enable dashboard widgets customization
VITE_ENABLE_WIDGET_CUSTOMIZATION=true

# Enable keyboard shortcuts help
VITE_ENABLE_KEYBOARD_SHORTCUTS=true

# Enable offline mode (PWA)
VITE_ENABLE_OFFLINE_MODE=false

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# Enable debug mode (shows additional info in UI)
VITE_ENABLE_DEBUG=false

# =============================================================================
# Authentication
# =============================================================================
# Token refresh buffer in seconds (refresh token before expiry)
# Default: 300 = refresh 5 minutes before expiry
VITE_TOKEN_REFRESH_BUFFER=300

# Remember me duration in days
VITE_REMEMBER_ME_DAYS=7

# =============================================================================
# Cache Configuration
# =============================================================================
# Default React Query stale time in milliseconds
# Default: 120000 = 2 minutes
VITE_QUERY_STALE_TIME=120000

# Default React Query cache time in milliseconds
# Default: 600000 = 10 minutes
VITE_QUERY_CACHE_TIME=600000

# =============================================================================
# Printing
# =============================================================================
# Default paper size for print: A4 | Letter | Legal
VITE_PRINT_PAPER_SIZE=A4

# Default print orientation: portrait | landscape
VITE_PRINT_ORIENTATION=portrait

# Company header for printed documents
VITE_PRINT_COMPANY_HEADER=true

# =============================================================================
# External Services (Optional)
# =============================================================================
# Google Maps API Key (for logistics/delivery tracking)
# VITE_GOOGLE_MAPS_API_KEY=

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=

# Firebase configuration (for push notifications)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# =============================================================================
# PWA Configuration (Optional)
# =============================================================================
# PWA app theme color
VITE_PWA_THEME_COLOR=#1976d2

# PWA background color
VITE_PWA_BACKGROUND_COLOR=#ffffff

# =============================================================================
# Development Only (ignored in production builds)
# =============================================================================
# Enable mock API responses
VITE_ENABLE_MOCK_API=false

# Mock API delay in milliseconds
VITE_MOCK_API_DELAY=500

# Enable React Query DevTools
VITE_ENABLE_QUERY_DEVTOOLS=false

# Enable Redux DevTools
VITE_ENABLE_REDUX_DEVTOOLS=false
